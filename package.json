{
  "name": "bankingangular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "SET NODE_OPTIONS=--openssl-legacy-provider && ng serve",
    "build": "SET NODE_OPTIONS=--openssl-legacy-provider && ng build",
    "watch": "SET NODE_OPTIONS=--openssl-legacy-provider && ng build --watch --configuration development",
    "test": "SET NODE_OPTIONS=--openssl-legacy-provider && ng test",
    "api-gen": "ng-openapi-gen --input ./src/app/swagger/swagger.json --output src/app/services"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~12.2.0",
    "@angular/common": "~12.2.0",
    "@angular/compiler": "~12.2.0",
    "@angular/core": "~12.2.0",
    "@angular/forms": "~12.2.0",
    "@angular/platform-browser": "~12.2.0",
    "@angular/platform-browser-dynamic": "~12.2.0",
    "@angular/router": "~12.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~6.6.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~12.2.18",
    "@angular/cli": "~12.2.18",
    "@angular/compiler-cli": "~12.2.0",
    "@types/jasmine": "~3.8.0",
    "@types/node": "^12.11.1",
    "jasmine-core": "~3.8.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-openapi-gen": "^0.12.1",
    "typescript": "~4.3.5"
  }
}
